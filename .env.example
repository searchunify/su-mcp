# Docker image
IMAGE=searchunifyutils/su-mcp:latest

# Port mapping
EXPOSED_PORT=3000
MCP_HTTP_PORT=3000

# Memory limit
MEMORY=512m

# OAuth — required for Claude public directory
OAUTH_ENCRYPTION_KEY=   # Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_ISSUER_URL=https://mcp.searchunify.com

# Redis — optional (falls back to in-memory if not set)
# REDIS_URL=redis://redis:6379

# SU SDK timeout (optional, default 60000ms)
# SU_TIMEOUT=60000
