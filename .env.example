# ── Minimal (self-hosted, no OAuth) ────────────────────────────────────────
IMAGE=searchunifyutils/su-mcp:latest
EXPOSED_PORT=3000
MCP_HTTP_PORT=3000
MEMORY=512m

# ── Full (OAuth enabled, for Claude public directory) ───────────────────────
# Required only when running as a managed instance with OAuth.
# Generate key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_ENCRYPTION_KEY=
MCP_ISSUER_URL=https://mcp.searchunify.com

# Redis — NOT required. Leave empty to use in-memory store (tokens lost on restart).
# REDIS_URL=redis://redis:6379

# ── OpenAI MCP listing — domain verification ────────────────────────────────
# Token from the OpenAI dashboard (Settings → MCP Servers → Verify Domain).
# Required only on the public-facing server when verifying ownership with OpenAI.
# OPENAI_DOMAIN_VERIFICATION_TOKEN=
